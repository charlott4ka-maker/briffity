{
  "version": 2,
  "buildCommand": "echo 'Static site — no build needed'",
  "outputDirectory": "public",
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/brief/(.*)", "dest": "/public/brief.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
