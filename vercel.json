{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/ua",
      "destination": "/index.html"
    },
    {
      "source": "/brief/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/((?!js|css|assets|api).*)",
      "destination": "/index.html"
    }
  ]
}
