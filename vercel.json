{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/en", "destination": "/index.html" },
    { "source": "/ua", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/signup", "destination": "/index.html" },
    { "source": "/mybriefs", "destination": "/index.html" },
    { "source": "/brief/:slug", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
